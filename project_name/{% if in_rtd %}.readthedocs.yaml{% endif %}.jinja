# Read the Docs configuration file for MkDocs projects
# See https://docs.readthedocs.io/en/stable/config-file/v2.html for details

version: 2

build:
  os: ubuntu-lts-latest
  tools:
    python: latest

python:
  install:
    - method: uv
      command: sync
      groups:
        - docs

mkdocs:
  configuration: mkdocs.yml
  fail_on_warning: true
